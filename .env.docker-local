# aha-cli bug-fix-0324 本地 Docker 测试环境
# 连接本地 docker compose 服务

# 使用独立的数据目录
AHA_HOME_DIR=~/.aha-bugfix-0324

# 本地 Docker 服务端口
AHA_SERVER_URL=http://localhost:3005
AHA_WEBAPP_URL=http://localhost:8081

DEBUG=1
DANGEROUSLY_LOG_TO_SERVER_FOR_AI_AUTO_DEBUGGING=true
NODE_NO_WARNINGS=1

# Genome Hub
GENOME_HUB_URL=http://localhost:3006
HUB_PUBLISH_KEY=dev-key-change-in-prod
