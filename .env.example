# Aha CLI Environment Configuration
# Copy this file to .env.dev-local-server and fill in your values
# DO NOT commit files with real values

# Home directory for Aha data (default: ~/.aha)
# AHA_HOME_DIR=~/.aha-dev

# Server URL (default: production server)
# AHA_SERVER_URL=http://localhost:3005

# Web app URL (default: production web app)
# AHA_WEBAPP_URL=http://localhost:8081

# Genome Hub marketplace URL (default: https://genome-hub.aha.engineering)
# GENOME_HUB_URL=http://localhost:3006

# Key for publishing genome feedback to marketplace (optional)
# HUB_PUBLISH_KEY=your-key-here

# Enable debug logging
# DEBUG=1

# Suppress Node.js warnings
# NODE_NO_WARNINGS=1

# Enable dangerous server-side logging for AI debugging (never enable in production)
# DANGEROUSLY_LOG_TO_SERVER_FOR_AI_AUTO_DEBUGGING=true
